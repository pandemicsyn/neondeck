{
  "name": "@neondeck/github-webhook-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Cloudflare Worker that relays signed GitHub webhooks to authenticated WebSocket clients.",
  "type": "module",
  "scripts": {
    "check": "npm run lint && npm run types:check && npm run typecheck && npm run test && npm run deploy:dry-run",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "lint": "oxlint src test --deny-warnings --no-error-on-unmatched-pattern",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "types": "wrangler types",
    "types:check": "wrangler types --check"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.5",
    "@types/node": "26.1.1",
    "oxlint": "1.73.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.111.0"
  },
  "engines": {
    "node": ">=26.4.0"
  }
}
