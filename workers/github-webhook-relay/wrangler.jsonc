{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "neondeck-github-webhook-relay",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],
  "secrets": {
    "required": ["GITHUB_WEBHOOK_SECRET", "WS_CLIENT_SECRET"]
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.01
    }
  }
}
