KILOCODE_API_KEY="your-kilo-api-key"
FLUE_AGENT_MODEL="kilocode/kilo/auto"
GITHUB_TOKEN="your-github-token"

# Optional. Use when your Kilo account routes requests through a specific org.
KILOCODE_ORGANIZATION_ID="your-kilo-organization-id"

# Optional. If omitted, the server looks up the authenticated GitHub user.
GITHUB_LOGIN="your-github-login"
