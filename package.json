{
  "name": "neondeck",
  "version": "1.0.0-beta.4",
  "description": "Local companion-display dashboard and Flue agent server for neondeck.",
  "homepage": "https://neondeck.dev",
  "bin": {
    "neondeck": "bin/neondeck.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "web/dist/",
    "shared/",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/test-setup.ts",
    "src/runtime-home/app-db/migrations/",
    "src/skills/",
    "config/",
    "SOUL.md",
    "README.md",
    "DEVELOPMENT.md",
    "CHANGELOG.md",
    "LICENSE",
    "drizzle.config.ts"
  ],
  "workspaces": [
    "docs"
  ],
  "scripts": {
    "build": "npm run build:dashboard && npm run docs:build",
    "build:dashboard": "npm run build:web && npm run build:server",
    "build:server": "flue build --target node && node scripts/copy-runtime-assets.mjs",
    "build:web": "vite build --config web/vite.config.ts",
    "changeset": "changeset",
    "check": "npm run lint && npm run check:layers && npm run db:check && npm run typecheck && npm run test",
    "check:layers": "node scripts/check-import-layers.mjs",
    "check:npm-package": "node scripts/check-npm-package.mjs",
    "dev": "concurrently -n server,web -c blue,green \"flue dev --target node\" \"vite --config web/vite.config.ts --host 127.0.0.1\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint src web/src web/vite.config.ts vitest.config.ts vitest.unit.config.ts vitest.integration.config.ts vitest.git.config.ts vitest.shared.ts --react-plugin --jsx-a11y-plugin --vitest-plugin --import-plugin --no-error-on-unmatched-pattern",
    "lint:fix": "npm run lint -- --fix",
    "prepack": "npm run build:dashboard",
    "prepare": "git config core.hooksPath .githooks || true",
    "hooks:install": "git config core.hooksPath .githooks",
    "cli": "tsx src/cli/index.ts",
    "db:check": "node scripts/check-db-migrations.mjs",
    "db:generate": "drizzle-kit generate --output json --config drizzle.config.ts",
    "init": "tsx src/cli/index.ts init",
    "raycast:build": "npm --prefix raycast install && npm --prefix raycast run build",
    "raycast:install": "npm --prefix raycast install && npm --prefix raycast run dev",
    "raycast:lint": "npm --prefix raycast run lint",
    "run:display": "flue run display-assistant --target node --server /api/flue --input '{\"message\":\"Say hello in one sentence.\"}'",
    "secrets:check": "gitleaks git --redact --no-banner --log-opts=--all",
    "secrets:check:staged": "gitleaks git --staged --redact --no-banner",
    "setup": "node src/setup.ts",
    "reset:flue-db": "node scripts/reset-flue-db.mjs",
    "smoke:autopilot": "node scripts/autopilot-smoke.mjs",
    "smoke:kilo": "node scripts/kilo-smoke.mjs",
    "smoke:learning": "vitest run --config vitest.integration.config.ts src/learning-workflow-smoke.test.ts",
    "smoke:npm-pack": "node scripts/npm-pack-smoke.mjs",
    "start": "node dist/server.mjs",
    "test": "npm run test:unit",
    "test:all": "npm run test && npm run test:git && npm run test:integration",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:git": "vitest run --config vitest.git.config.ts",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "package:app": "node scripts/package-app-release.mjs",
    "release:app": "npm run build:dashboard && npm run package:app",
    "release:npm:check": "npm run lint && npm run check:layers && npm run db:check && npm run typecheck && npm run test:all && npm run build && npm run check:npm-package && npm run smoke:npm-pack",
    "report:file-sizes": "node scripts/file-size-report.mjs",
    "typecheck": "npm run typecheck:app && npm run docs:check",
    "typecheck:app": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "verify": "npm run lint && npm run check:layers && npm run db:check && npm run typecheck && npm run test:all && npm run build && npm run check:npm-package && npm run smoke:npm-pack && npm run format:check",
    "version-packages": "changeset version",
    "docs:build": "npm --workspace @neondeck/docs-site run build",
    "docs:check": "npm --workspace @neondeck/docs-site run check",
    "docs:deploy": "npm --workspace @neondeck/docs-site run deploy",
    "docs:dev": "npm --workspace @neondeck/docs-site run dev",
    "docs:astro-dev": "npm --workspace @neondeck/docs-site run astro-dev",
    "docs:preview": "npm --workspace @neondeck/docs-site run preview"
  },
  "keywords": [
    "flue",
    "dashboard",
    "agent",
    "xeneon-edge"
  ],
  "author": "Florian Hines",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pandemicsyn/neondeck.git"
  },
  "bugs": {
    "url": "https://github.com/pandemicsyn/neondeck/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@flue/react": "1.0.0-beta.9",
    "@flue/runtime": "1.0.0-beta.9",
    "@flue/sdk": "1.0.0-beta.9",
    "@hono/node-server": "^2.0.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pierre/diffs": "1.2.12",
    "@pierre/trees": "1.0.0-beta.5",
    "@tanstack/react-query": "^5.101.2",
    "ajv": "^8.20.0",
    "commander": "^15.0.0",
    "croner": "10.0.1",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ssh2": "^1.17.0",
    "systeminformation": "^5.31.11",
    "tsx": "^4.23.0",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@flue/cli": "1.0.0-beta.9",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "1.0.0-rc.4",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
