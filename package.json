{
  "name": "neondeck",
  "version": "1.0.0",
  "description": "Local companion-display dashboard and Flue agent server for neondeck.",
  "homepage": "https://neondeck.dev",
  "private": true,
  "bin": {
    "neondeck": "src/cli.ts"
  },
  "workspaces": [
    "webapp"
  ],
  "scripts": {
    "build": "npm run build:dashboard && npm run webapp:build",
    "build:dashboard": "npm run build:web && flue build --target node",
    "build:server": "flue build --target node",
    "build:web": "vite build --config web/vite.config.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "dev": "concurrently -n server,web -c blue,green \"flue dev --target node\" \"vite --config web/vite.config.ts --host 127.0.0.1\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint src web/src web/vite.config.ts vitest.config.ts vitest.unit.config.ts vitest.integration.config.ts vitest.shared.ts --react-plugin --jsx-a11y-plugin --vitest-plugin --import-plugin --no-error-on-unmatched-pattern",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "git config core.hooksPath .githooks || true",
    "hooks:install": "git config core.hooksPath .githooks",
    "cli": "tsx src/cli.ts",
    "init": "tsx src/cli.ts init",
    "raycast:build": "npm --prefix raycast install && npm --prefix raycast run build",
    "raycast:install": "npm --prefix raycast install && npm --prefix raycast run dev",
    "raycast:lint": "npm --prefix raycast run lint",
    "run:display": "flue run display-assistant --target node --server /api/flue --input '{\"message\":\"Say hello in one sentence.\"}'",
    "secrets:check": "gitleaks git --redact --no-banner --log-opts=--all",
    "secrets:check:staged": "gitleaks git --staged --redact --no-banner",
    "setup": "node src/setup.ts",
    "smoke:autopilot": "node scripts/autopilot-smoke.mjs",
    "smoke:kilo": "node scripts/kilo-smoke.mjs",
    "start": "node dist/server.mjs",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:all": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "package:app": "node scripts/package-app-release.mjs",
    "release:app": "npm run build:dashboard && npm run package:app",
    "typecheck": "npm run typecheck:app && npm run webapp:check",
    "typecheck:app": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test:all && npm run format:check && npm run build",
    "webapp:build": "npm --workspace webapp run build",
    "webapp:check": "npm --workspace webapp run check",
    "webapp:deploy": "npm --workspace webapp run deploy",
    "webapp:dev": "npm --workspace webapp run dev",
    "webapp:astro-dev": "npm --workspace webapp run astro-dev",
    "webapp:preview": "npm --workspace webapp run preview"
  },
  "keywords": [
    "flue",
    "dashboard",
    "agent",
    "xeneon-edge"
  ],
  "author": "Florian Hines",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pandemicsyn/neondeck.git"
  },
  "bugs": {
    "url": "https://github.com/pandemicsyn/neondeck/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@flue/react": "^1.0.0-beta.7",
    "@flue/runtime": "^1.0.0-beta.7",
    "@flue/sdk": "^1.0.0-beta.7",
    "@hono/node-server": "^2.0.6",
    "@tanstack/react-query": "^5.101.2",
    "commander": "^15.0.0",
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ssh2": "^1.17.0",
    "systeminformation": "^5.31.11",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@flue/cli": "^1.0.0-beta.9",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.0",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
