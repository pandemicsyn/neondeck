{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neondeck.dev/schemas/dashboard.schema.json",
  "title": "Neondeck dashboard config",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "display", "theme", "layout"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1,
      "description": "Version marker for one-time dashboard layout migrations."
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "preset": {
          "type": "string",
          "minLength": 1,
          "description": "Target display profile used for defaults and previews. Rendering remains responsive to the actual viewport."
        }
      }
    },
    "theme": {
      "enum": ["light", "dark", "system"]
    },
    "appearance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "density": {
          "enum": ["compact", "comfortable", "large"],
          "description": "Controls dashboard spacing density."
        },
        "textScale": {
          "type": "number",
          "minimum": 0.9,
          "maximum": 1.75,
          "description": "Fine-grained text scaling multiplier for companion-display readability."
        }
      }
    },
    "notifications": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "toasts": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "minimumLevel": {
              "enum": ["info", "ready", "attention", "urgent"],
              "default": "ready"
            },
            "readyDurationMs": {
              "type": "integer",
              "default": 6000,
              "description": "Automatically dismiss ready toasts after this many milliseconds. Values are clamped from 1000 through 60000."
            },
            "maxVisible": {
              "type": "integer",
              "default": 3,
              "description": "Maximum visible toast rows. Values are clamped from 1 through 3."
            }
          }
        }
      }
    },
    "windows": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/windowProfile"
      },
      "description": "Named desktop window launch profiles used by `neondeck open <profile>`."
    },
    "statusline": {
      "type": "object",
      "additionalProperties": true,
      "required": ["position", "pluginId"],
      "properties": {
        "position": {
          "enum": ["top", "bottom"]
        },
        "pluginId": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object"
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "rows", "regions"],
      "properties": {
        "mode": {
          "enum": ["auto", "xeneon", "stacked"],
          "description": "Responsive layout behavior. Auto adapts to the viewport, xeneon prefers the configured grid, stacked forces vertical panels."
        },
        "columns": {
          "type": "integer",
          "minimum": 1
        },
        "rows": {
          "type": "integer",
          "minimum": 1
        },
        "regions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/region"
          }
        }
      }
    }
  },
  "$defs": {
    "region": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "column",
        "row",
        "columnSpan",
        "rowSpan",
        "tabs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "columnSpan": {
          "type": "integer",
          "minimum": 1
        },
        "rowSpan": {
          "type": "integer",
          "minimum": 1
        },
        "defaultTab": {
          "type": "string",
          "description": "Must match one tab id in this region. Enforced by Neondeck runtime validation.",
          "minLength": 1
        },
        "tabs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/tab"
          }
        }
      }
    },
    "tab": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title", "pluginId"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "pluginId": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object"
        }
      }
    },
    "windowProfile": {
      "type": "object",
      "additionalProperties": false,
      "dependentRequired": {
        "width": ["height"],
        "height": ["width"],
        "x": ["y"],
        "y": ["x"]
      },
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "kiosk": {
          "type": "boolean"
        }
      }
    }
  }
}
