{
  "display": {
    "width": 2560,
    "height": 720
  },
  "theme": "dark",
  "layout": {
    "columns": 12,
    "rows": 6,
    "regions": [
      {
        "id": "statusline",
        "title": "Status line",
        "pluginId": "host-metrics",
        "column": 1,
        "row": 1,
        "columnSpan": 12,
        "rowSpan": 1,
        "config": {}
      },
      {
        "id": "github",
        "title": "GITHUB · @you",
        "pluginId": "github-pr-list",
        "column": 1,
        "row": 2,
        "columnSpan": 3,
        "rowSpan": 3,
        "config": {
          "limit": 12
        }
      },
      {
        "id": "watches",
        "title": "WATCHES",
        "pluginId": "active-watches",
        "column": 1,
        "row": 5,
        "columnSpan": 3,
        "rowSpan": 2,
        "config": {
          "limit": 8
        }
      },
      {
        "id": "briefing",
        "title": "BRIEFING",
        "pluginId": "briefing-panel",
        "column": 4,
        "row": 2,
        "columnSpan": 2,
        "rowSpan": 3,
        "config": {
          "actionLimit": 4
        }
      },
      {
        "id": "memory",
        "title": "MEMORY",
        "pluginId": "memory-panel",
        "column": 4,
        "row": 5,
        "columnSpan": 2,
        "rowSpan": 2,
        "config": {
          "limit": 5
        }
      },
      {
        "id": "chat",
        "title": "FLUE AGENT · triage.ts",
        "pluginId": "flue-chat",
        "column": 9,
        "row": 2,
        "columnSpan": 4,
        "rowSpan": 5,
        "config": {
          "agentName": "display-assistant",
          "sessions": [
            {
              "id": "neondeck-main",
              "label": "Primary",
              "placeholder": "Ask about your active work..."
            }
          ],
          "quickCommands": [
            {
              "label": "Repo",
              "command": "/repo-status"
            },
            {
              "label": "Queue",
              "command": "/review-queue"
            },
            {
              "label": "CI",
              "command": "/explain-ci"
            },
            {
              "label": "PR",
              "command": "/summarize-pr"
            },
            {
              "label": "Draft",
              "command": "/draft-pr-description"
            },
            {
              "label": "Prep",
              "command": "/prepare-pr"
            },
            {
              "label": "Review",
              "command": "/review-local"
            },
            {
              "label": "Memory",
              "command": "/memory"
            },
            {
              "label": "Doctor",
              "command": "/dev-doctor"
            }
          ]
        }
      },
      {
        "id": "runtime",
        "title": "RUNTIME",
        "pluginId": "runtime-overview",
        "column": 6,
        "row": 2,
        "columnSpan": 3,
        "rowSpan": 3,
        "config": {
          "repoLimit": 5,
          "jobLimit": 5,
          "skillLimit": 5,
          "memoryLimit": 5,
          "workflowEventLimit": 6
        }
      },
      {
        "id": "subagents",
        "title": "SUBAGENTS",
        "pluginId": "subagent-summary",
        "column": 6,
        "row": 5,
        "columnSpan": 3,
        "rowSpan": 2,
        "config": {
          "eventLimit": 4
        }
      }
    ]
  }
}
