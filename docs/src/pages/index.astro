---
import DeckMockup from '../components/DeckMockup.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const dashboardConfig = `{
  "display": { "width": 2560, "height": 720 },
  "theme": "dark",
  "layout": {
    "columns": 12,
    "rows": 6,
    "regions": [
      { "id": "statusline", "pluginId": "host-metrics", "columnSpan": 12 },
      { "id": "github", "pluginId": "github-pr-list", "columnSpan": 4 },
      { "id": "chat", "pluginId": "flue-chat", "columnSpan": 8 }
    ]
  }
}`;
---

<BaseLayout
  title="neondeck · autonomous developer assistant for companion displays"
  description="A local-first autonomous developer assistant designed to live full time on a companion display, vertical panel, or sensor-panel style deck."
>
  <div class="site-shell">
    <SiteNav />
    <main>
      <section class="hero">
        <div class="hero-bg" aria-hidden="true">
          <div class="hero-wash pink"></div>
          <div class="hero-wash teal"></div>
          <div class="hero-wash violet"></div>
          <div class="hero-wash cyan"></div>
          <div class="hero-stripes"></div>
          <div class="hero-vignette"></div>
        </div>
        <div class="hero-center">
          <p class="kicker">OPEN · ALWAYS-ON · BUILT ON FLUE</p>
          <h1>
            An autonomous dev assistant<br /><span class="hero-gradient"
              >for your always-on deck.</span
            >
          </h1>
          <p class="hero-copy">
            Your PR queue, active watches, deployments, and alerts in one
            always-on console that Neon manages for you. Run it on a companion
            display, a vertical panel, or a sensor deck beside your main monitor.
          </p>
          <div class="command">
            <span class="command-code"
              ><span>$</span> npm create neondeck@latest</span
            >
            <button type="button" data-copy-command="npm create neondeck@latest"
              >copy</button
            >
          </div>
          <div class="hero-actions">
            <a
              class="button hero-primary"
              href="https://github.com/pandemicsyn/neondeck">★ Star on GitHub</a
            >
            <a class="button secondary hero-secondary" href="/docs/"
              >Read the docs →</a
            >
          </div>
        </div>
      </section>

      <section id="panel" class="section">
        <div class="container">
          <div class="section-header">
            <h2>The deck, live.</h2>
            <p>
              An example 32:9 layout for the Corsair Xeneon Edge. Neondeck is
              designed for horizontal, vertical, compact, and custom surfaces
              that Neon itself can configure for you.
            </p>
          </div>
          <DeckMockup />
        </div>
      </section>

      <section id="features" class="section-tight">
        <div class="container">
          <div class="section-header">
            <h2>Built for work in progress.</h2>
            <p>Neon watches your PRs, prepares fixes, and keeps the busywork moving.</p>
          </div>
          <div class="feature-grid">
            <article class="feature">
              <div class="spark pink"></div>
              <h3>Your PRs, with CI status at a glance</h3>
              <p>
                Every open PR you've authored across your repos in one panel,
                with live check status and a flag when one goes stale.
              </p>
            </article>
            <article class="feature">
              <div class="spark teal"></div>
              <h3>Watch a PR, then let autopilot move it</h3>
              <p>
                Neon tracks a PR through merge, checks, and deploy. When a
                review requests changes or CI breaks, autopilot prepares the fix
                in an isolated worktree, runs your checks, and hands you the diff
                or pushes it — your call, per repo.
              </p>
            </article>
            <article class="feature">
              <div class="spark"></div>
              <h3>Review and approve PRs on the deck</h3>
              <p>
                Read the diff, leave inline comments, resolve threads, and
                submit an approval or change request — without switching to
                github.com. The verdict is always yours.
              </p>
            </article>
            <article class="feature">
              <div class="spark violet"></div>
              <h3>Handoff, both directions</h3>
              <p>
                Delegate real work to dedicated agents like Kilo or Codex — then
                have them hand the finished PR back to Neon to follow through
                checks and deployment.
              </p>
            </article>
            <article class="feature">
              <div class="spark pink"></div>
              <h3>Briefings and routines on a schedule</h3>
              <p>
                A morning briefing pulls your PRs, watches, CI failures, and
                next actions. Or add your own routines — a saved prompt that
                runs on a timer.
              </p>
            </article>
            <article class="feature">
              <div class="spark teal"></div>
              <h3>Sandboxed, gated execution</h3>
              <p>
                Agents work in throwaway worktrees, never your live checkout.
                Shell commands clear an approval policy first — or run off your
                machine entirely on an <code>exe.dev</code> sandbox VM.
              </p>
            </article>
            <article class="feature">
              <div class="spark"></div>
              <h3>Memory that learns from your work</h3>
              <p>
                Neon remembers your preferences and each repo's conventions, and
                learns from your conversations and PR feedback. What it wants to
                remember is always a suggestion you approve, never a silent
                change.
              </p>
            </article>
            <article class="feature">
              <div class="spark violet"></div>
              <h3>Ask Neon to set up the deck</h3>
              <p>
                Neon configures itself — repos, models, schedules, even its own
                layout and display. Want to change something? Just ask.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="config" class="section">
        <div class="container config-grid">
          <div>
            <p class="kicker">CONFIG OR CHAT</p>
            <h2>The layout is a file. Or a request.</h2>
            <p class="hero-copy">
              Manually tune layouts, text scale, fonts, panel regions, and
              plugin config in runtime-home <code>dashboard.json</code>, or ask
              Neon to adapt the deck for your size, orientation, and
              constraints.
            </p>
            <div class="hero-actions">
              <a class="button secondary" href="/docs/getting-started/"
                >Get started</a
              >
            </div>
          </div>
          <div class="code-window" aria-label="dashboard configuration example">
            <div class="code-header">
              <span class="code-dot"></span><span class="code-dot"></span><span
                class="code-dot"></span>
            </div>
            <pre><code>{dashboardConfig}</code></pre>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
