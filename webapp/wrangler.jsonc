{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "neondeck-site",
  "compatibility_date": "2026-06-27",
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    {
      "pattern": "neondeck.dev",
      "custom_domain": true
    },
    {
      "pattern": "www.neondeck.dev",
      "custom_domain": true
    }
  ]
}
