---
type Props = {
  description?: string;
  title?: string;
};

const {
  description = 'A local companion-display dashboard and durable Flue agent console for the Corsair Xeneon Edge.',
  title = 'neondeck',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://neondeck.dev');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonical.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <svg
      class="svg-defs"
      width="0"
      height="0"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <filter id="ndCamoWarp">
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.011 0.018"
            numOctaves="3"
            seed="7"
            result="n"></feTurbulence>
          <feDisplacementMap
            in="SourceGraphic"
            in2="n"
            scale="64"
            xChannelSelector="R"
            yChannelSelector="G"></feDisplacementMap>
        </filter>
      </defs>
    </svg>
    <slot />
    <script is:inline>
      const root = document.documentElement;
      const urlLook = new URLSearchParams(window.location.search).get('look');
      const storedLook = window.localStorage.getItem('neondeck-look');
      const initialLook =
        urlLook === 'deck' || urlLook === 'light' || urlLook === 'camo'
          ? urlLook
          : storedLook === 'deck' ||
              storedLook === 'light' ||
              storedLook === 'camo'
            ? storedLook
            : 'camo';

      function setLook(look) {
        root.dataset.look = look;
        root.dataset.theme = look === 'light' ? 'light' : 'dark';
        window.localStorage.setItem('neondeck-look', look);
        document.querySelectorAll('[data-look-button]').forEach((button) => {
          button.setAttribute(
            'aria-pressed',
            button.dataset.lookButton === look ? 'true' : 'false',
          );
        });
      }

      document.querySelectorAll('[data-look-button]').forEach((button) => {
        button.addEventListener('click', () =>
          setLook(button.dataset.lookButton),
        );
      });

      document.querySelectorAll('[data-copy-command]').forEach((button) => {
        button.addEventListener('click', async () => {
          const command = button.dataset.copyCommand;
          if (!command) return;
          try {
            await navigator.clipboard.writeText(command);
            const original = button.textContent;
            button.textContent = 'copied';
            window.setTimeout(() => {
              button.textContent = original;
            }, 1400);
          } catch {
            button.textContent = 'copy';
          }
        });
      });

      setLook(initialLook);
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #0e0f13;
    --bg-strong: #090a0f;
    --surface: #12141b;
    --chrome: #070810;
    --ink: #f7fbff;
    --body: #d7f7ff;
    --muted: rgba(215, 247, 255, 0.68);
    --faint: rgba(215, 247, 255, 0.44);
    --line: rgba(255, 255, 255, 0.1);
    --line-weak: rgba(255, 255, 255, 0.06);
    --pink: #ff4fb8;
    --teal: #00b7c7;
    --cyan: #69e6ff;
    --violet: #8b4dff;
    --card: #0e0f13;
    --code-bg: #070810;
    --code-ink: #d7f7ff;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
  }

  :root[data-theme='light'] {
    color-scheme: light;
    --bg: #e7f3f7;
    --bg-strong: #dcedf2;
    --surface: #ffffff;
    --chrome: #0a0c12;
    --ink: #13171e;
    --body: #222b34;
    --muted: rgba(26, 34, 44, 0.74);
    --faint: rgba(26, 34, 44, 0.46);
    --line: rgba(18, 40, 55, 0.14);
    --line-weak: rgba(18, 40, 55, 0.09);
    --cyan: #0093a8;
    --pink: #e0399b;
    --teal: #0093a8;
    --violet: #7a37e6;
    --card: #ffffff;
    --code-bg: #f7fcff;
    --code-ink: #13171e;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--body);
    -webkit-font-smoothing: antialiased;
  }

  body::selection {
    background: var(--pink);
    color: var(--bg);
  }

  a {
    color: inherit;
  }

  .site-shell {
    overflow: hidden;
  }

  .svg-defs {
    position: absolute;
    pointer-events: none;
  }

  .container {
    width: min(1180px, calc(100vw - 48px));
    margin: 0 auto;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 19px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .brand-mark {
    width: 14px;
    height: 14px;
    transform: rotate(45deg);
    background: linear-gradient(135deg, var(--pink), var(--cyan));
    box-shadow: 0 0 14px rgba(255, 79, 184, 0.7);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 18px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--cyan);
  }

  .look-toggle {
    display: inline-flex;
    margin-left: 2px;
  }

  .look-toggle button {
    border: 1px solid var(--line);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    padding: 6px 10px;
  }

  .look-toggle button + button {
    margin-left: -1px;
  }

  .look-toggle button[aria-pressed='true'] {
    border-color: var(--cyan);
    background: color-mix(in srgb, var(--cyan) 14%, transparent);
    color: var(--cyan);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--cyan);
    background: var(--cyan);
    color: var(--bg);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 14px;
    font-weight: 600;
    padding: 13px 22px;
    text-decoration: none;
  }

  .button:hover {
    background: var(--pink);
    border-color: var(--pink);
  }

  .button.secondary {
    background: transparent;
    color: var(--cyan);
  }

  .button.secondary:hover {
    background: rgba(105, 230, 255, 0.08);
    border-color: var(--cyan);
    color: var(--ink);
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(72px, 9vw, 92px) 0 clamp(72px, 10vw, 110px);
    border-bottom: 1px solid var(--line);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-wash {
    position: absolute;
    background: radial-gradient(
      circle at 50% 50%,
      var(--wash-color),
      transparent 62%
    );
    filter: blur(70px);
  }

  .hero-wash.pink {
    --wash-color: rgba(255, 79, 184, 0.55);
    top: -25%;
    left: -12%;
    width: 60%;
    height: 130%;
  }

  .hero-wash.teal {
    --wash-color: rgba(0, 183, 199, 0.5);
    top: -30%;
    left: 28%;
    width: 55%;
    height: 140%;
  }

  .hero-wash.violet {
    --wash-color: rgba(139, 77, 255, 0.5);
    top: -10%;
    right: -12%;
    width: 55%;
    height: 130%;
  }

  .hero-wash.cyan {
    --wash-color: rgba(105, 230, 255, 0.4);
    bottom: -40%;
    left: 18%;
    width: 60%;
    height: 120%;
  }

  .hero-stripes {
    position: absolute;
    inset: -12%;
    background: repeating-linear-gradient(
      102deg,
      transparent 0 24px,
      rgba(10, 12, 16, 0.92) 24px 56px
    );
    filter: url('#ndCamoWarp');
    mix-blend-mode: multiply;
    opacity: 0.78;
    animation: nd-drift 26s ease-in-out infinite alternate;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(14, 15, 19, 0.2),
      rgba(14, 15, 19, 0.55) 70%,
      var(--bg)
    );
  }

  :root[data-look='deck'] .hero {
    background: #0b0c10;
  }

  :root[data-look='deck'] .hero-bg {
    left: 58%;
    opacity: 0.72;
  }

  :root[data-look='deck'] .hero-wash {
    display: none;
  }

  :root[data-look='deck'] .hero-wash.teal {
    --wash-color: rgba(0, 183, 199, 0.45);
    display: block;
    top: -20%;
    left: auto;
    right: -10%;
    width: 90%;
    height: 140%;
    background: radial-gradient(
      circle at 60% 40%,
      var(--wash-color),
      transparent 64%
    );
  }

  :root[data-look='deck'] .hero-stripes {
    inset: -14%;
    background: repeating-linear-gradient(
      98deg,
      transparent 0 26px,
      rgba(6, 8, 11, 0.95) 26px 60px
    );
    animation: none;
    opacity: 0.85;
  }

  :root[data-look='deck'] .hero-vignette {
    background: linear-gradient(
      90deg,
      #0b0c10 0 28%,
      rgba(11, 12, 16, 0.62) 62%,
      rgba(11, 12, 16, 0.1)
    );
  }

  :root[data-theme='light'] .hero-wash {
    filter: blur(72px);
  }

  :root[data-theme='light'] .hero-wash.pink {
    --wash-color: rgba(255, 79, 184, 0.4);
  }

  :root[data-theme='light'] .hero-wash.teal {
    --wash-color: rgba(0, 183, 199, 0.34);
  }

  :root[data-theme='light'] .hero-wash.violet {
    --wash-color: rgba(139, 77, 255, 0.32);
  }

  :root[data-theme='light'] .hero-wash.cyan {
    --wash-color: rgba(0, 183, 199, 0.3);
  }

  :root[data-theme='light'] .hero-stripes {
    background: repeating-linear-gradient(
      102deg,
      transparent 0 24px,
      rgba(30, 28, 46, 0.14) 24px 56px
    );
    opacity: 0.8;
  }

  :root[data-theme='light'] .hero-vignette {
    background: linear-gradient(
      180deg,
      rgba(231, 243, 247, 0.12),
      rgba(231, 243, 247, 0.5) 72%,
      var(--bg)
    );
  }

  :root[data-look='deck'][data-theme='light'] .hero-bg {
    left: 0;
    opacity: 0.74;
  }

  :root[data-look='deck'][data-theme='light'] .hero-wash {
    display: block;
  }

  :root[data-look='deck'][data-theme='light'] .hero-vignette {
    background: linear-gradient(
      180deg,
      rgba(231, 243, 247, 0.12),
      rgba(231, 243, 247, 0.5) 72%,
      var(--bg)
    );
  }

  @keyframes nd-drift {
    0% {
      transform: translate3d(0, 0, 0);
    }

    100% {
      transform: translate3d(-3%, 1.5%, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-stripes {
      animation: none;
    }
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(420px, 1.08fr);
    gap: clamp(34px, 5vw, 72px);
    align-items: center;
  }

  .hero-center {
    position: relative;
    z-index: 2;
    max-width: 1040px;
    margin: 0 auto;
    padding-inline: 28px;
    text-align: center;
  }

  .kicker {
    margin: 0 0 22px;
    color: var(--cyan);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.24em;
  }

  h1,
  h2,
  h3 {
    font-family: 'Chakra Petch', sans-serif;
    color: var(--ink);
  }

  h1 {
    margin: 0 auto;
    font-size: clamp(2.6rem, 6.4vw, 5.4rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    text-shadow: 0 0 38px rgba(255, 79, 184, 0.35);
  }

  h1 span {
    color: var(--cyan);
  }

  .hero-gradient {
    background: linear-gradient(
      92deg,
      var(--pink),
      var(--cyan) 55%,
      var(--violet)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-copy {
    max-width: 62ch;
    margin: 26px auto 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 20px;
  }

  .hero-actions .button {
    padding-inline: 26px;
  }

  .command {
    display: inline-flex;
    align-items: stretch;
    margin-top: 38px;
    padding: 0;
    border: 1px solid rgba(105, 230, 255, 0.28);
    background: rgba(8, 9, 12, 0.72);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.4),
      0 18px 50px rgba(0, 0, 0, 0.5);
    color: var(--body);
    backdrop-filter: blur(4px);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 15px;
  }

  .command span {
    color: var(--pink);
  }

  .command-code {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    white-space: nowrap;
  }

  .command button {
    border: 0;
    border-left: 1px solid rgba(105, 230, 255, 0.28);
    background: transparent;
    color: var(--cyan);
    cursor: pointer;
    font: inherit;
    font-size: 12px;
    letter-spacing: 0.08em;
    padding: 0 16px;
    text-transform: uppercase;
  }

  .command button:hover {
    background: rgba(105, 230, 255, 0.12);
  }

  .hero-primary {
    border-color: var(--pink);
    background: var(--pink);
    box-shadow: 0 0 28px rgba(255, 79, 184, 0.5);
    color: #0e0f13;
  }

  .hero-primary:hover {
    border-color: var(--cyan);
    background: var(--cyan);
    color: #0e0f13;
  }

  .hero-secondary {
    border-color: rgba(105, 230, 255, 0.5);
    color: var(--cyan);
  }

  .hero-secondary:hover {
    border-color: var(--cyan);
    background: rgba(105, 230, 255, 0.08);
    color: var(--ink);
  }

  :root[data-look='deck'] .hero-primary {
    border-color: var(--cyan);
    background: var(--cyan);
    box-shadow: none;
  }

  :root[data-look='deck'] .hero-primary:hover {
    border-color: var(--pink);
    background: var(--pink);
  }

  :root[data-theme='light'] .hero-primary {
    border-color: var(--pink);
    background: var(--pink);
    box-shadow: 0 10px 26px rgba(224, 57, 155, 0.32);
    color: #fcfdff;
  }

  :root[data-theme='light'] .hero-primary:hover {
    border-color: var(--cyan);
    background: var(--cyan);
    color: #fcfdff;
  }

  :root[data-theme='light'] .command {
    border-color: rgba(18, 40, 55, 0.2);
    background: #0a0c12;
    box-shadow: 0 18px 50px rgba(20, 40, 60, 0.16);
  }

  .section {
    padding: clamp(62px, 8vw, 104px) 0;
  }

  .section-tight {
    padding: clamp(48px, 7vw, 78px) 0;
  }

  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }

  .section-header h2,
  .docs-prose h1,
  .docs-prose h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.3rem);
    line-height: 1;
    letter-spacing: -0.015em;
  }

  .section-header p {
    max-width: 44ch;
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .feature {
    min-height: 210px;
    background: var(--card);
    padding: 26px 24px;
  }

  .feature h3 {
    margin: 18px 0 8px;
    font-size: 18px;
  }

  .feature p,
  .docs-prose p,
  .docs-prose li {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.7;
  }

  .spark {
    width: 11px;
    height: 11px;
    transform: rotate(45deg);
    background: var(--cyan);
    box-shadow: 0 0 13px currentColor;
    color: var(--cyan);
  }

  .spark.pink {
    background: var(--pink);
    color: var(--pink);
  }

  .spark.teal {
    background: var(--teal);
    color: var(--teal);
  }

  .spark.violet {
    background: var(--violet);
    color: var(--violet);
  }

  .config-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(420px, 1fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .code-window {
    overflow: auto;
    border: 1px solid var(--line);
    background: var(--code-bg);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    line-height: 1.75;
  }

  .code-header {
    display: flex;
    gap: 7px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--line-weak);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--pink);
  }

  .code-dot:nth-child(2) {
    background: var(--teal);
  }

  .code-dot:nth-child(3) {
    background: var(--cyan);
  }

  pre {
    margin: 0;
    padding: 18px;
    color: var(--code-ink);
    white-space: pre;
  }

  code {
    font-family: 'IBM Plex Mono', monospace;
  }

  .docs-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 44px;
    padding: 58px 0 96px;
  }

  .docs-sidebar {
    position: sticky;
    top: 92px;
    align-self: start;
    display: grid;
    gap: 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
  }

  .docs-sidebar a {
    color: var(--muted);
    text-decoration: none;
  }

  .docs-sidebar a:hover {
    color: var(--cyan);
  }

  .docs-prose {
    max-width: 780px;
  }

  .docs-prose h1 {
    margin-bottom: 22px;
  }

  .docs-prose h2 {
    margin-top: 50px;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  .docs-prose a {
    color: var(--cyan);
  }

  .docs-prose pre {
    margin: 18px 0;
    border: 1px solid var(--line);
    background: var(--code-bg);
    overflow: auto;
  }

  .footer {
    border-top: 1px solid var(--line);
    padding: 34px 0;
    color: var(--faint);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .nav-link,
    .nav-cta {
      display: none;
    }

    .hero-grid,
    .config-grid,
    .docs-layout {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: clamp(2.3rem, 12vw, 4.3rem);
    }

    .command {
      font-size: 11px;
    }

    .command-code {
      gap: 9px;
      padding: 13px 14px;
    }

    .command button {
      padding: 0 12px;
    }

    .section-header {
      display: block;
    }

    .section-header p {
      margin-top: 16px;
    }

    .docs-sidebar {
      position: static;
      display: flex;
      flex-wrap: wrap;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 1ms !important;
      scroll-behavior: auto !important;
      transition-duration: 1ms !important;
    }
  }
</style>
