---
type Props = {
  description?: string;
  title?: string;
};

const {
  description = 'A local companion-display dashboard and durable Flue agent console for the Corsair Xeneon Edge.',
  title = 'neondeck',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://neondeck.dev');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonical.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #0e0f13;
    --bg-strong: #090a0f;
    --surface: #12141b;
    --chrome: #070810;
    --ink: #f7fbff;
    --body: #d7f7ff;
    --muted: rgba(215, 247, 255, 0.68);
    --faint: rgba(215, 247, 255, 0.44);
    --line: rgba(255, 255, 255, 0.1);
    --line-weak: rgba(255, 255, 255, 0.06);
    --pink: #ff4fb8;
    --teal: #00b7c7;
    --cyan: #69e6ff;
    --violet: #8b4dff;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(130deg, rgba(255, 79, 184, 0.12), transparent 23%),
      linear-gradient(62deg, transparent 48%, rgba(0, 183, 199, 0.11) 49%, transparent 67%),
      linear-gradient(110deg, transparent 15%, rgba(139, 77, 255, 0.12) 16%, transparent 29%),
      var(--bg);
    color: var(--body);
    -webkit-font-smoothing: antialiased;
  }

  body::selection {
    background: var(--pink);
    color: var(--bg);
  }

  a {
    color: inherit;
  }

  .site-shell {
    overflow: hidden;
  }

  .container {
    width: min(1180px, calc(100vw - 48px));
    margin: 0 auto;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--line);
    background: rgba(12, 13, 18, 0.86);
    backdrop-filter: blur(10px);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: "Chakra Petch", sans-serif;
    font-size: 19px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .brand-mark {
    width: 14px;
    height: 14px;
    transform: rotate(45deg);
    background: linear-gradient(135deg, var(--pink), var(--cyan));
    box-shadow: 0 0 14px rgba(255, 79, 184, 0.7);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 22px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--cyan);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--cyan);
    background: var(--cyan);
    color: var(--bg);
    font-family: "IBM Plex Mono", monospace;
    font-size: 14px;
    font-weight: 600;
    padding: 13px 22px;
    text-decoration: none;
  }

  .button:hover {
    background: var(--pink);
    border-color: var(--pink);
  }

  .button.secondary {
    background: transparent;
    color: var(--cyan);
  }

  .button.secondary:hover {
    background: rgba(105, 230, 255, 0.08);
    border-color: var(--cyan);
    color: var(--ink);
  }

  .hero {
    position: relative;
    padding: clamp(72px, 10vw, 124px) 0 clamp(70px, 9vw, 112px);
    border-bottom: 1px solid var(--line);
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(116deg, transparent 0 16%, rgba(255, 79, 184, 0.18) 16% 20%, transparent 20% 40%, rgba(0, 183, 199, 0.13) 40% 46%, transparent 46% 74%, rgba(139, 77, 255, 0.16) 74% 80%, transparent 80%),
      linear-gradient(63deg, transparent 0 30%, rgba(215, 247, 255, 0.045) 30% 36%, transparent 36% 64%, rgba(255, 79, 184, 0.08) 64% 68%, transparent 68%);
    opacity: 0.95;
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(420px, 1.08fr);
    gap: clamp(34px, 5vw, 72px);
    align-items: center;
  }

  .kicker {
    margin: 0 0 22px;
    color: var(--cyan);
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.24em;
  }

  h1,
  h2,
  h3 {
    font-family: "Chakra Petch", sans-serif;
    color: var(--ink);
  }

  h1 {
    max-width: 11ch;
    margin: 0;
    font-size: clamp(3.1rem, 8vw, 6rem);
    line-height: 0.93;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  h1 span {
    color: var(--cyan);
  }

  .hero-copy {
    max-width: 62ch;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .command {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 22px;
    border: 1px solid rgba(105, 230, 255, 0.32);
    background: rgba(7, 8, 16, 0.78);
    color: var(--body);
    font-family: "IBM Plex Mono", monospace;
    font-size: 14px;
    padding: 13px 16px;
  }

  .command span {
    color: var(--pink);
  }

  .section {
    padding: clamp(62px, 8vw, 104px) 0;
  }

  .section-tight {
    padding: clamp(48px, 7vw, 78px) 0;
  }

  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }

  .section-header h2,
  .docs-prose h1,
  .docs-prose h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.3rem);
    line-height: 1;
    letter-spacing: -0.015em;
  }

  .section-header p {
    max-width: 44ch;
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1px;
    border: 1px solid var(--line);
    background: var(--line);
  }

  .feature {
    min-height: 210px;
    background: rgba(14, 15, 19, 0.96);
    padding: 26px 24px;
  }

  .feature h3 {
    margin: 18px 0 8px;
    font-size: 18px;
  }

  .feature p,
  .docs-prose p,
  .docs-prose li {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.7;
  }

  .spark {
    width: 11px;
    height: 11px;
    transform: rotate(45deg);
    background: var(--cyan);
    box-shadow: 0 0 13px currentColor;
    color: var(--cyan);
  }

  .spark.pink {
    background: var(--pink);
    color: var(--pink);
  }

  .spark.teal {
    background: var(--teal);
    color: var(--teal);
  }

  .spark.violet {
    background: var(--violet);
    color: var(--violet);
  }

  .config-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(420px, 1fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .code-window {
    overflow: auto;
    border: 1px solid var(--line);
    background: var(--chrome);
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px;
    line-height: 1.75;
  }

  .code-header {
    display: flex;
    gap: 7px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--line-weak);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--pink);
  }

  .code-dot:nth-child(2) {
    background: var(--teal);
  }

  .code-dot:nth-child(3) {
    background: var(--cyan);
  }

  pre {
    margin: 0;
    padding: 18px;
    color: var(--body);
    white-space: pre;
  }

  code {
    font-family: "IBM Plex Mono", monospace;
  }

  .docs-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 44px;
    padding: 58px 0 96px;
  }

  .docs-sidebar {
    position: sticky;
    top: 92px;
    align-self: start;
    display: grid;
    gap: 10px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px;
  }

  .docs-sidebar a {
    color: var(--muted);
    text-decoration: none;
  }

  .docs-sidebar a:hover {
    color: var(--cyan);
  }

  .docs-prose {
    max-width: 780px;
  }

  .docs-prose h1 {
    margin-bottom: 22px;
  }

  .docs-prose h2 {
    margin-top: 50px;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  .docs-prose a {
    color: var(--cyan);
  }

  .docs-prose pre {
    margin: 18px 0;
    border: 1px solid var(--line);
    background: var(--chrome);
    overflow: auto;
  }

  .footer {
    border-top: 1px solid var(--line);
    padding: 34px 0;
    color: var(--faint);
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }

    .hero-grid,
    .config-grid,
    .docs-layout {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 12ch;
    }

    .section-header {
      display: block;
    }

    .section-header p {
      margin-top: 16px;
    }

    .docs-sidebar {
      position: static;
      display: flex;
      flex-wrap: wrap;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 1ms !important;
      scroll-behavior: auto !important;
      transition-duration: 1ms !important;
    }
  }
</style>
