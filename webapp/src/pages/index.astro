---
import DeckMockup from '../components/DeckMockup.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const dashboardConfig = `{
  "display": { "width": 2560, "height": 720 },
  "theme": "dark",
  "layout": {
    "columns": 12,
    "rows": 6,
    "regions": [
      { "id": "statusline", "pluginId": "host-metrics", "columnSpan": 12 },
      { "id": "github", "pluginId": "github-pr-list", "columnSpan": 4 },
      { "id": "chat", "pluginId": "flue-chat", "columnSpan": 8 }
    ]
  }
}`;
---

<BaseLayout
  title="neondeck · autonomous developer assistant for companion displays"
  description="A local-first autonomous developer assistant designed to live full time on a companion display, vertical panel, or sensor-panel style deck."
>
  <div class="site-shell">
    <SiteNav />
    <main>
      <section class="hero">
        <div class="hero-bg" aria-hidden="true">
          <div class="hero-wash pink"></div>
          <div class="hero-wash teal"></div>
          <div class="hero-wash violet"></div>
          <div class="hero-wash cyan"></div>
          <div class="hero-stripes"></div>
          <div class="hero-vignette"></div>
        </div>
        <div class="hero-center">
          <p class="kicker">OPEN · ALWAYS-ON · BUILT ON FLUE</p>
          <h1>
            An autonomous dev assistant<br /><span class="hero-gradient"
              >for your always-on deck.</span
            >
          </h1>
          <p class="hero-copy">
            Your GitHub queue, watched PRs and issues, tracked deployments,
            alerts, and assistant sessions in one local, agent-managed console.
            Run it on a companion display, a vertical panel, or a sensor deck on
            your primary monitor.
          </p>
          <div class="command">
            <span class="command-code"
              ><span>$</span> npm create neondeck@latest</span
            >
            <button type="button" data-copy-command="npm create neondeck@latest"
              >copy</button
            >
          </div>
          <div class="hero-actions">
            <a
              class="button hero-primary"
              href="https://github.com/pandemicsyn/neondeck">★ Star on GitHub</a
            >
            <a class="button secondary hero-secondary" href="/docs/"
              >Read the docs →</a
            >
          </div>
        </div>
      </section>

      <section id="panel" class="section">
        <div class="container">
          <div class="section-header">
            <h2>The deck, live.</h2>
            <p>
              An example 32:9 layout for the Corsair Xeneon Edge. Neondeck is
              designed for horizontal, vertical, compact, and custom surfaces
              that Neon itself can configure for you.
            </p>
          </div>
          <DeckMockup />
        </div>
      </section>

      <section id="features" class="section-tight">
        <div class="container">
          <div class="section-header">
            <h2>Built for work in progress.</h2>
            <p>
              Neon helps you automate developer busy work.
            </p>
          </div>
          <div class="feature-grid">
            <article class="feature">
              <div class="spark pink"></div>
              <h3>GitHub work queue</h3>
              <p>
                Review requests, authored and assigned PRs, failing checks,
                stale work, and related GitHub issues are ranked from
                server-side GitHub data.
              </p>
            </article>
            <article class="feature">
              <div class="spark teal"></div>
              <h3>Quiet watches</h3>
              <p>
                Watched PRs, release checks, and deploy targets persist
                watermarks, survive restarts, and stay quiet until something
                meaningful changes.
              </p>
            </article>
            <article class="feature">
              <div class="spark"></div>
              <h3>Alerts that know priority</h3>
              <p>
                Notifications dedupe repeated watcher output and separate
                passive updates from ready, attention, and urgent states.
              </p>
            </article>
            <article class="feature">
              <div class="spark violet"></div>
              <h3>Durable sessions</h3>
              <p>
                Neon conversations can be named, pinned, archived, searched, and
                linked back to repos, watches, tasks, and workflow summaries.
              </p>
            </article>
            <article class="feature">
              <div class="spark pink"></div>
              <h3>Autopilot worktrees</h3>
              <p>
                When policy allows, Neon prepares review or CI fixes in managed
                worktrees, verifies checks, and explains the result before push.
              </p>
            </article>
            <article class="feature">
              <div class="spark teal"></div>
              <h3>Local-first runtime</h3>
              <p>
                Config, schedules, skills, memories, approvals, and Flue session
                state live on your machine under a runtime home you control.
              </p>
            </article>
            <article class="feature">
              <div class="spark"></div>
              <h3>Scheduled briefings</h3>
              <p>
                Morning briefings and review digests pull queue state, active
                watches, CI failures, and recommended next actions on a schedule.
              </p>
            </article>
            <article class="feature">
              <div class="spark violet"></div>
              <h3>Workflow observability</h3>
              <p>
                Flue runs, command results, subagent summaries, approvals, and
                failures stay inspectable without turning raw logs into the UI.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="config" class="section">
        <div class="container config-grid">
          <div>
            <p class="kicker">CONFIG OR CHAT</p>
            <h2>The layout is a file. Or a request.</h2>
            <p class="hero-copy">
              Manually tune layouts, text scale, fonts, panel regions, and
              plugin config in runtime-home <code>dashboard.json</code>, or ask
              Neon to adapt the deck for your size, orientation, and constraints.
            </p>
            <div class="hero-actions">
              <a class="button secondary" href="/docs/getting-started/"
                >Get started</a
              >
            </div>
          </div>
          <div class="code-window" aria-label="dashboard configuration example">
            <div class="code-header">
              <span class="code-dot"></span><span class="code-dot"></span><span
                class="code-dot"></span>
            </div>
            <pre><code>{dashboardConfig}</code></pre>
          </div>
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
